# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# Gemini
GEMINI_API_KEY=

# Google OAuth (Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob

# App config
ALLOW_PRIVATE_CHATS=

# Internal service-to-service token (omni-backend <-> omni-business)
# Generate with: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=
